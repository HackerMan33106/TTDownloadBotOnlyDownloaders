# Telegram Bot Token (required)
BOT_TOKEN=your_bot_token_here

# Trash Group ID for caching media files (required)
TRASH_GROUP_ID=-1001234567890

# Permanent Admin User IDs (comma-separated)
PERMANENT_ADMIN=123456789

# Whitelist User IDs (comma-separated)
WHITELIST_USERS=123456789,987654321

# Whitelist Group IDs (comma-separated, negative numbers)
WHITELIST_GROUPS=-1001234567890,-1009876543210

# Spotify API Credentials (optional)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# Local Telegram Bot API Server (optional)
USE_LOCAL_API=false
LOCAL_API_URL=http://127.0.0.1:8200

# Telegram API Credentials for Local Bot API (optional)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Data Directory (optional, default: current directory)
DATA_DIR=./data
